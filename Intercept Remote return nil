local function intercept(remoteStr, argument)
    return function()
        -- Evaluar la cadena de jerarquía para obtener el objeto remoto
        local remote = loadstring("return " .. remoteStr)()

        -- Obtener la metatabla del objeto remoto
        local mt = getrawmetatable(remote)
        local oldNC = mt.__namecall
        setreadonly(mt, false)

        -- Sobrescribir la llamada al método __namecall
        mt.__namecall = newcclosure(function(self, ...)
            local args = {...}
            if not argument or (args[1] == argument) then
                return nil
            end
            return oldNC(self, ...)
        end)

        setreadonly(mt, true)
    end
end

return intercept
